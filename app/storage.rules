rules_version = '2';
// Photos : lisibles par tous (elles s'affichent sur la carte publique),
// envoyables seulement si l'appli est connectée, images uniquement, < 15 Mo.
service firebase.storage {
  match /b/{bucket}/o {
    match /photos/{name}/{file} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 15 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
