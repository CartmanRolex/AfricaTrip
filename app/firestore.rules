rules_version = '2';
// Règles simples et "délire entre potes" : le site lit tout (carte publique),
// et on n'accepte l'écriture que si l'appli est connectée (Firebase Anonymous,
// invisible pour l'utilisateur). Ça bloque les bots random sans mot de passe.
// Quelques garde-fous de forme pour éviter d'écrire n'importe quoi.
service cloud.firestore {
  match /databases/{db}/documents {

    function signed() { return request.auth != null; }
    function num(x) { return x is number; }

    match /positions/{name} {
      allow read: if true;
      allow write: if signed()
        && num(request.resource.data.lat) && num(request.resource.data.lng);
    }
    match /tracks/{name}/points/{pt} {
      allow read: if true;
      allow create: if signed()
        && num(request.resource.data.lat) && num(request.resource.data.lng);
      allow update, delete: if false;
    }
    match /crew/{name} {
      allow read: if true;
      allow write: if signed();
    }
    match /photos/{id} {
      allow read: if true;
      allow create: if signed() && request.resource.data.url is string;
      allow delete: if signed();   // l'app permet de retirer ses photos
      allow update: if false;
    }
  }
}
