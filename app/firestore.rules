rules_version = '2';
// Le site lit TOUT (carte publique, aucune connexion), mais l'écriture est
// réservée au COMPTE UNIQUE de l'équipage : un seul email + un mot de passe
// partagé (Firebase Email/Password). Personne d'autre ne peut donc polluer la
// carte, même si la config Firebase est publique. Le mot de passe n'est jamais
// dans le code : Firebase le gère (haché) côté serveur.
// -> `signed()` = connecté AVEC ce compte précis (email exact). Doit
//    correspondre à AUTH_EMAIL de app/www/firebase-config.js et à l'utilisateur
//    créé dans la console (Authentication → Users).
// Quelques garde-fous de forme pour éviter d'écrire n'importe quoi.
service cloud.firestore {
  match /databases/{db}/documents {

    function signed() {
      return request.auth != null
        && request.auth.token.email == 'equipage@expedition-afrique.app';
    }
    function num(x) { return x is number; }

    match /positions/{name} {
      allow read: if true;
      allow write: if signed()
        && num(request.resource.data.lat) && num(request.resource.data.lng);
    }
    match /tracks/{name}/points/{pt} {
      allow read: if true;
      allow create: if signed()
        && num(request.resource.data.lat) && num(request.resource.data.lng);
      allow update, delete: if false;
    }
    match /crew/{name} {
      allow read: if true;
      allow write: if signed();
    }
    match /photos/{id} {
      allow read: if true;
      allow create: if signed() && request.resource.data.url is string;
      allow delete: if signed();   // l'app permet de retirer ses photos
      // édition de la SEULE légende (le compte équipage ne peut pas altérer
      // url/position/etc. d'une photo, juste ajouter/changer `caption`).
      allow update: if signed()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['caption']);
    }
  }
}
